{
  "headers": [
    {
      "source": "/mission-control",
      "headers": [
        { "key": "x-mc-route", "value": "true" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/mission-control/politica-de-privacidade", "destination": "/index.html" },
    { "source": "/mission-control", "destination": "/index.html" },
    { "source": "/((?!mission-control).*)", "destination": "/index.html" }
  ]
}
